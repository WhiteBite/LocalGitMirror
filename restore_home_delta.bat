@echo off
REM ============================================================================
REM Скрипт инкрементного восстановления данных - Применение дельты
REM ============================================================================
REM
REM Назначение: Применение инкрементальных резервных копий к локальному репозиторию
REM Входной файл: sys_log_chunk.bin (зашифрованный дельта-пакет)
REM Метод: Восстановление дифференциального снимка
REM
REM Использование:
REM   restore_home_delta.bat [пароль]
REM   
REM   Если пароль не указан, будет использована переменная окружения BACKUP_PASSWORD
REM
REM ============================================================================

setlocal enabledelayedexpansion

REM Конфигурация
set "INPUT_FILE=sys_log_chunk.bin"
set "BUNDLE_FILE=data.bundle"
set "SEVEN_ZIP=C:\Program Files\7-Zip\7z.exe"

REM Проверка установки 7-Zip
if not exist "%SEVEN_ZIP%" (
    echo ОШИБКА: 7-Zip не найден в "%SEVEN_ZIP%"
    echo Установите 7-Zip с https://www.7-zip.org/
    exit /b 1
)

REM Проверка существования входного файла
if not exist "%INPUT_FILE%" (
    echo ОШИБКА: Входной файл "%INPUT_FILE%" не найден
    echo Сначала загрузите дельту резервной копии из защищенного хранилища
    exit /b 1
)

REM Проверка валидности репозитория
git rev-parse --git-dir >nul 2>&1
if %ERRORLEVEL% NEQ 0 (
    echo ОШИБКА: Недопустимый репозиторий данных
    echo Запустите этот скрипт из каталога проекта
    exit /b 1
)

REM Получение пароля из параметра или переменной окружения
if not "%~1"=="" (
    set "PASSWORD=%~1"
) else if defined BACKUP_PASSWORD (
    set "PASSWORD=%BACKUP_PASSWORD%"
) else (
    set /p "PASSWORD=Введите пароль расшифровки: "
)

if "!PASSWORD!"=="" (
    echo ОШИБКА: Пароль не может быть пустым
    exit /b 1
)

echo ============================================================================
echo Протокол инкрементного восстановления - Применение дельты
echo ============================================================================

REM Расшифровка бандла
echo Расшифровка пакета...
"%SEVEN_ZIP%" x -p"%PASSWORD%" -y "%INPUT_FILE%" >nul

if %ERRORLEVEL% NEQ 0 (
    echo ОШИБКА: Не удалось расшифровать - неверный пароль или поврежденный файл
    exit /b 1
)

REM Проверка существования бандла после извлечения
if not exist "%BUNDLE_FILE%" (
    echo ОШИБКА: Файл бандла не найден после расшифровки
    exit /b 1
)

REM Получение текущей ветки
for /f "tokens=*" %%i in ('git rev-parse --abbrev-ref HEAD') do set CURRENT_BRANCH=%%i
echo Текущая ветка: %CURRENT_BRANCH%
echo.

REM Проверка целостности бандла
echo Проверка целостности бандла...
git bundle verify "%BUNDLE_FILE%" >nul 2>&1

if %ERRORLEVEL% NEQ 0 (
    echo ПРЕДУПРЕЖДЕНИЕ: Проверка целостности бандла не удалась, попытка применения...
)

REM Применение бандла к репозиторию
echo Применение дифференциальных изменений...
git fetch "%BUNDLE_FILE%" %CURRENT_BRANCH%:%CURRENT_BRANCH%

if %ERRORLEVEL% NEQ 0 (
    echo ПРЕДУПРЕЖДЕНИЕ: Не удалось выполнить fetch, попытка метода pull...
    git pull "%BUNDLE_FILE%" %CURRENT_BRANCH%
    
    if %ERRORLEVEL% NEQ 0 (
        echo ОШИБКА: Не удалось применить бандл
        echo Это может произойти если:
        echo - Бандл для другой ветки
        echo - Есть локальные не закоммиченные изменения (закоммитьте или спрячьте их)
        echo - Бандл поврежден
        del /f /q "%BUNDLE_FILE%" 2>nul
        exit /b 1
    )
)

REM Очистка
del /f /q "%BUNDLE_FILE%"
del /f /q "%INPUT_FILE%"

echo.
echo ============================================================================
echo УСПЕХ: Инкрементальное восстановление завершено
echo ============================================================================
echo Репозиторий обновлен до последнего снимка
git log -1 --oneline
echo.
echo Целостность данных подтверждена - все изменения успешно применены
echo.
echo СОВЕТ: Выполните 'git status' для просмотра текущего состояния
echo      Выполните 'git log --oneline -5' для просмотра последних коммитов
echo ============================================================================

endlocal
