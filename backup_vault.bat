@echo off
REM ============================================================================
REM Скрипт резервного копирования хранилища - Автоматическое создание зашифрованной резервной копии
REM ============================================================================
REM
REM Назначение: Создание зашифрованной резервной копии каталога storage
REM Выходной файл: sys_dump_logs.bin (нейтральное имя для дискретной передачи)
REM Шифрование: AES-256 с шифрованием заголовков
REM
REM Использование:
REM   backup_vault.bat [пароль]
REM   
REM   Если пароль не указан, будет использована переменная окружения BACKUP_PASSWORD
REM   или запрошен интерактивно
REM
REM ============================================================================

setlocal enabledelayedexpansion

REM Конфигурация
set "SOURCE_DIR=storage"
set "OUTPUT_FILE=sys_dump_logs.bin"
set "SEVEN_ZIP=C:\Program Files\7-Zip\7z.exe"

REM Проверка установки 7-Zip
if not exist "%SEVEN_ZIP%" (
    echo ОШИБКА: 7-Zip не найден в "%SEVEN_ZIP%"
    echo Установите 7-Zip с https://www.7-zip.org/
    exit /b 1
)

REM Проверка существования исходного каталога
if not exist "%SOURCE_DIR%" (
    echo ОШИБКА: Исходный каталог "%SOURCE_DIR%" не найден
    exit /b 1
)

REM Получение пароля из параметра, переменной окружения или запрос
if not "%~1"=="" (
    set "PASSWORD=%~1"
) else if defined BACKUP_PASSWORD (
    set "PASSWORD=%BACKUP_PASSWORD%"
) else (
    set /p "PASSWORD=Введите пароль для резервного копирования: "
)

if "!PASSWORD!"=="" (
    echo ОШИБКА: Пароль не может быть пустым
    exit /b 1
)

REM Создание резервной копии с шифрованием
echo Создание зашифрованной резервной копии...
echo Источник: %SOURCE_DIR%
echo Выходной файл: %OUTPUT_FILE%
echo.

REM Параметры 7-Zip:
REM a          - добавить в архив
REM -t7z       - использовать формат 7z
REM -p         - установить пароль
REM -mhe=on    - зашифровать заголовки (скрывает имена файлов и структуру)
REM -mx=9      - максимальное сжатие
REM -mfb=64    - количество быстрых байт для deflate
REM -md=32m    - размер словаря
REM -ms=on     - сплошной архив
REM -mhe=on    - зашифровать заголовки архива
REM -p         - пароль (AES-256 шифрование)

"%SEVEN_ZIP%" a -t7z -p"%PASSWORD%" -mhe=on -mx=9 -mfb=64 -md=32m -ms=on "%OUTPUT_FILE%" "%SOURCE_DIR%\*"

if %ERRORLEVEL% EQU 0 (
    echo.
    echo ============================================================================
    echo УСПЕХ: Резервная копия успешно создана
    echo ============================================================================
    echo Файл: %OUTPUT_FILE%
    for %%A in ("%OUTPUT_FILE%") do echo Размер: %%~zA байт
    echo.
    echo ВАЖНО:
    echo - Храните пароль в безопасности
    echo - Имя файла нейтральное для дискретной передачи
    echo - Заголовки зашифрованы - структура скрыта
    echo - Используется AES-256 шифрование
    echo.
    echo Для восстановления:
    echo   "%SEVEN_ZIP%" x -p[пароль] %OUTPUT_FILE%
    echo.
    echo Автоудаление после загрузки (опционально):
    timeout /t 5 /nobreak >nul
    REM Раскомментируйте следующую строку для автоудаления после успешного создания
    REM del /f /q "%OUTPUT_FILE%"
    echo ============================================================================
) else (
    echo.
    echo ОШИБКА: Не удалось создать резервную копию
    exit /b 1
)

endlocal
