@echo off
REM ============================================================================
REM Администратор сетевого хранилища - Настройка брандмауэра
REM ============================================================================
REM
REM Назначение: Добавление правила брандмауэра для доступа по HTTPS (порт 443)
REM
REM ВАЖНО: Запускайте этот скрипт от имени администратора
REM
REM ============================================================================

echo Проверка прав администратора...
net session >nul 2>&1
if %ERRORLEVEL% NEQ 0 (
    echo.
    echo ОШИБКА: Требуются права администратора
    echo.
    echo Щелкните правой кнопкой по файлу и выберите "Запуск от имени администратора"
    echo.
    pause
    exit /b 1
)

echo.
echo ============================================================================
echo Администратор сетевого хранилища - Настройка брандмауэра
echo ============================================================================
echo.

REM Проверка существующего правила
netsh advfirewall firewall show rule name="Администратор сетевого хранилища (HTTPS)" >nul 2>&1
if %ERRORLEVEL% EQU 0 (
    echo Правило уже существует. Удаление старого правила...
    netsh advfirewall firewall delete rule name="Администратор сетевого хранилища (HTTPS)"
)

REM Добавление нового правила
echo Добавление правила брандмауэра для порта 443...
netsh advfirewall firewall add rule ^
    name="Администратор сетевого хранилища (HTTPS)" ^
    dir=in ^
    action=allow ^
    protocol=TCP ^
    localport=443 ^
    profile=any ^
    description="Разрешить HTTPS доступ к Администратору сетевого хранилища"

if %ERRORLEVEL% EQU 0 (
    echo.
    echo ============================================================================
    echo УСПЕХ: Правило брандмауэра успешно добавлено
    echo ============================================================================
    echo.
    echo Порт 443 теперь доступен из сети
    echo.
    echo Вы можете получить доступ к серверу по адресу:
    echo   https://192.168.0.104:443
    echo.
    echo Чтобы удалить это правило позже, выполните:
    echo   netsh advfirewall firewall delete rule name="Администратор сетевого хранилища (HTTPS)"
    echo.
    echo ============================================================================
) else (
    echo.
    echo ОШИБКА: Не удалось добавить правило брандмауэра
    echo.
)

pause
