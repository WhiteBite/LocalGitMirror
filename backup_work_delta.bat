@echo off
REM ============================================================================
REM Скрипт инкрементного резервного копирования данных - Генерация дельты
REM ============================================================================
REM
REM Назначение: Создание инкрементных резервных копий для эффективной передачи данных
REM Выходной файл: sys_log_chunk.bin (зашифрованный дельта-пакет)
REM Метод: Технология дифференциального снимка
REM
REM Использование:
REM   backup_work_delta.bat [пароль]
REM   
REM   Если пароль не указан, будет использована переменная окружения BACKUP_PASSWORD
REM
REM ============================================================================

setlocal enabledelayedexpansion

REM Конфигурация
set "BUNDLE_FILE=data.bundle"
set "OUTPUT_FILE=sys_log_chunk.bin"
set "SYNC_STATE=.last_sync"
set "SEVEN_ZIP=C:\Program Files\7-Zip\7z.exe"

REM Проверка установки 7-Zip
if not exist "%SEVEN_ZIP%" (
    echo ОШИБКА: 7-Zip не найден в "%SEVEN_ZIP%"
    echo Установите 7-Zip с https://www.7-zip.org/
    exit /b 1
)

REM Проверка валидности репозитория
git rev-parse --git-dir >nul 2>&1
if %ERRORLEVEL% NEQ 0 (
    echo ОШИБКА: Недопустимый репозиторий данных
    echo Запустите этот скрипт из каталога проекта
    exit /b 1
)

REM Получение пароля из параметра или переменной окружения
if not "%~1"=="" (
    set "PASSWORD=%~1"
) else if defined BACKUP_PASSWORD (
    set "PASSWORD=%BACKUP_PASSWORD%"
) else (
    set /p "PASSWORD=Введите пароль шифрования: "
)

if "!PASSWORD!"=="" (
    echo ОШИБКА: Пароль не может быть пустым
    exit /b 1
)

echo ============================================================================
echo Протокол инкрементного резервного копирования - Генерация дельты
echo ============================================================================

REM Проверка первого синхронизационного запуска или инкрементального
if exist "%SYNC_STATE%" (
    REM Инкрементальное резервное копирование - создание дельты
    set /p LAST_HASH=<"%SYNC_STATE%"
    echo Режим: ИНКРЕМЕНТАЛЬНОЕ (дельта от предыдущего снимка)
    echo Предыдущая контрольная точка: !LAST_HASH!
    echo.
    echo Генерация дифференциального пакета...
    
    REM Проверка наличия новых коммитов с последней синхронизации
    git rev-list HEAD...!LAST_HASH! --count >nul 2>&1
    if %ERRORLEVEL% NEQ 0 (
        echo ОШИБКА: Недопустимый хеш контрольной точки в .last_sync
        echo Удалите файл .last_sync и запустите снова для полного резервного копирования
        exit /b 1
    )
    
    REM Создание бандла с изменениями с последней синхронизации
    git bundle create "%BUNDLE_FILE%" HEAD ^!LAST_HASH!
    
    if %ERRORLEVEL% NEQ 0 (
        echo ОШИБКА: Не удалось создать инкрементальный бандл
        echo Это может произойти, если нет новых изменений
        echo Попробуйте: git log --oneline !LAST_HASH!..HEAD
        exit /b 1
    )
) else (
    REM Полное резервное копирование - первый запуск
    echo Режим: ПОЛНОЕ (начальный снимок)
    echo.
    echo Генерация полного пакета...
    
    REM Создание полного бандла
    git bundle create "%BUNDLE_FILE%" --all
    
    if %ERRORLEVEL% NEQ 0 (
        echo ОШИБКА: Не удалось создать полный бандл
        exit /b 1
    )
)

REM Проверка размера бандла
for %%A in ("%BUNDLE_FILE%") do set BUNDLE_SIZE=%%~zA
echo Размер бандла: %BUNDLE_SIZE% байт
echo.

REM Шифрование бандла с AES-256 и шифрованием заголовков
echo Шифрование пакета...
"%SEVEN_ZIP%" a -t7z -p"%PASSWORD%" -mhe=on -mx=9 -mfb=64 -md=32m -ms=on "%OUTPUT_FILE%" "%BUNDLE_FILE%" >nul

if %ERRORLEVEL% NEQ 0 (
    echo ОШИБКА: Не удалось зашифровать
    del /f /q "%BUNDLE_FILE%" 2>nul
    exit /b 1
)

REM Обновление состояния синхронизации
echo Обновление контрольной точки...
git rev-parse HEAD > "%SYNC_STATE%"

REM Очистка временного бандла
del /f /q "%BUNDLE_FILE%"

echo.
echo ============================================================================
echo УСПЕХ: Инкрементальное резервное копирование завершено
echo ============================================================================
for %%A in ("%OUTPUT_FILE%") do echo Выходной файл: %OUTPUT_FILE% (%%~zA байт)
git rev-parse HEAD
echo.
echo Следующие шаги:
echo 1. Загрузите %OUTPUT_FILE% в защищенное хранилище через File Manager
echo 2. Проверьте целостность данных на удаленном терминале
echo 3. Запустите этот скрипт снова для следующего инкрементального резервного копирования
echo.
echo ПРИМЕЧАНИЕ: Храните файл %SYNC_STATE% - он отслеживает состояние резервного копирования
echo       Не удаляйте его, если хотите начать заново с полным резервным копированием
echo.
echo СОВЕТ: Установите переменную окружения BACKUP_PASSWORD для избежания запросов пароля
echo      Пример: set BACKUP_PASSWORD=ваш_пароль
echo ============================================================================

endlocal
