<idea-plugin>
  <id>localgitmirror.idea.orchestrator</id>
  <name>LocalGitMirror</name>
  <vendor email="dev@localgitmirror" url="https://localhost">LocalGitMirror</vendor>

  <description><![CDATA[
  LocalGitMirror transport plugin.
  Send branches/commits and pull changes back.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>

  <resource-bundle>messages.LocalGitMirrorBundle</resource-bundle>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="localgitmirror.idea.settings.MirrorSettingsService"/>
    <applicationService serviceImplementation="localgitmirror.idea.settings.OperationsHistoryService"/>
    <applicationConfigurable instance="localgitmirror.idea.settings.MirrorSettingsConfigurable"
                             id="localgitmirror.settings"
                             displayName="LocalGitMirror"
                             groupId="tools"/>
    <toolWindow id="LocalGitMirror"
                factoryClass="localgitmirror.idea.ui.LocalGitMirrorToolWindowFactory"
                anchor="bottom"
                icon="AllIcons.Toolwindows.ToolWindowMessages"/>

    <notificationGroup id="LocalGitMirror"
                       displayType="BALLOON"
                       isLogByDefault="true"
                       bundle="messages.LocalGitMirrorBundle"
                       key="notification.group.name"/>

    <postStartupActivity implementation="localgitmirror.idea.startup.PullCheckStartupActivity"/>
  </extensions>

  <actions>
    <!-- Main group: shown as submenu in ToolsMenu, VCS menu, ProjectView -->
    <group id="LocalGitMirror.Group" text="LocalGitMirror" description="LocalGitMirror actions" popup="true">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <add-to-group group-id="VcsGroup" anchor="last"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
    </group>

    <!-- Compact group: shown in VCS log context menus (only essentials) -->
    <group id="LocalGitMirror.ContextGroup" text="LocalGitMirror" description="LocalGitMirror actions" popup="true">
      <add-to-group group-id="Vcs.Log.ContextMenu" anchor="last"/>
      <add-to-group group-id="Vcs.FileHistory.ContextMenu" anchor="last"/>
    </group>

    <!-- ── Sync actions ── -->
    <action id="LocalGitMirror.SyncCurrentBranch"
            class="localgitmirror.idea.actions.SyncCurrentBranchToMirrorAction"
            text="Send current" description="Send current branch to Mirror"/>

    <action id="LocalGitMirror.SyncBranch"
            class="localgitmirror.idea.actions.SyncBranchToMirrorAction"
            text="Send branch…" description="Send selected branch to Mirror"/>

    <action id="LocalGitMirror.SyncGitLabMR"
            class="localgitmirror.idea.actions.SyncGitLabMrToMirrorAction"
            text="Send MR/PR…" description="Send MR/PR source branch to Mirror"/>

    <action id="LocalGitMirror.SendSelectedCommits"
            class="localgitmirror.idea.actions.SendSelectedCommitsToMirrorAction"
            text="Send commits…" description="Send selected commits to Mirror"/>

    <action id="LocalGitMirror.PushAs"
            class="localgitmirror.idea.actions.PushAsAction"
            text="Send as…" description="Send current HEAD to Mirror under a different branch name"/>

    <!-- ── Pull actions ── -->
    <action id="LocalGitMirror.SyncPull"
            class="localgitmirror.idea.actions.PullFromMirrorAction"
            text="Sync pull…" description="Pull changes from Mirror via encrypted sync"/>

    <action id="LocalGitMirror.PullBack"
            class="localgitmirror.idea.actions.PullBackFromRemoteAction"
            text="Pull back…" description="Pull changes back from remote"/>

    <action id="LocalGitMirror.ApplyLocalSync"
            class="localgitmirror.idea.actions.ApplyLocalDumpAction"
            text="Apply local sync package…" description="Apply local encrypted sync package"/>

    <!-- ── Diagnostics ── -->
    <action id="LocalGitMirror.Preflight"
            class="localgitmirror.idea.actions.PreflightCheckAction"
            text="Preflight" description="Run preflight diagnostics before sync"/>

    <action id="LocalGitMirror.DryRun"
            class="localgitmirror.idea.actions.DryRunSyncAction"
            text="Dry-run (send)" description="Preview send plan without upload"/>

    <action id="LocalGitMirror.DryRunPull"
            class="localgitmirror.idea.actions.DryRunPullSyncAction"
            text="Dry-run (pull)" description="Preview incoming changes from Mirror"/>

    <!-- Main menu: all actions with separators -->
    <group id="LocalGitMirror.FullGroup">
      <add-to-group group-id="LocalGitMirror.Group" anchor="last"/>
      <reference ref="LocalGitMirror.SyncCurrentBranch"/>
      <reference ref="LocalGitMirror.SyncBranch"/>
      <reference ref="LocalGitMirror.SyncGitLabMR"/>
      <reference ref="LocalGitMirror.SendSelectedCommits"/>
      <reference ref="LocalGitMirror.PushAs"/>
      <separator/>
      <reference ref="LocalGitMirror.SyncPull"/>
      <reference ref="LocalGitMirror.PullBack"/>
      <reference ref="LocalGitMirror.ApplyLocalSync"/>
      <separator/>
      <reference ref="LocalGitMirror.Preflight"/>
      <reference ref="LocalGitMirror.DryRun"/>
      <reference ref="LocalGitMirror.DryRunPull"/>
    </group>

    <!-- Context menu: only essentials -->
    <group id="LocalGitMirror.ContextInner">
      <add-to-group group-id="LocalGitMirror.ContextGroup" anchor="last"/>
      <reference ref="LocalGitMirror.SyncCurrentBranch"/>
      <reference ref="LocalGitMirror.SyncBranch"/>
      <reference ref="LocalGitMirror.PushAs"/>
      <separator/>
      <reference ref="LocalGitMirror.SyncPull"/>
      <reference ref="LocalGitMirror.PullBack"/>
    </group>
  </actions>
</idea-plugin>
